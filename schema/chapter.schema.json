{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://soul-property/chapter.schema.json",
  "title": "ChapterData",
  "description": "一份章節的完整內容資料。引擎只認此格式，新增章節無需改引擎。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "chapterId", "resident", "day", "night", "truth", "endings"],
  "definitions": {
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allFlags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "anyFlags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "notFlags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "minVars": { "type": "object", "additionalProperties": { "type": "number" } },
        "maxVars": { "type": "object", "additionalProperties": { "type": "number" } }
      }
    },
    "effect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["var", "delta"],
      "properties": {
        "var": { "type": "string", "minLength": 1 },
        "delta": { "type": "number" }
      }
    },
    "expression": { "type": "string", "enum": ["calm", "uneasy", "broken"] }
  },
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "chapterId": { "type": "string", "minLength": 1 },
    "opening": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text"],
        "properties": {
          "speaker": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    },
    "cast": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "resident": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "age", "portraits", "obsessionOneLiner"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "age": { "type": "integer", "minimum": 0 },
        "portraits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["calm", "uneasy", "broken"],
          "properties": {
            "calm": { "type": "string", "minLength": 1 },
            "uneasy": { "type": "string", "minLength": 1 },
            "broken": { "type": "string", "minLength": 1 }
          }
        },
        "obsessionOneLiner": { "type": "string", "minLength": 1 }
      }
    },
    "day": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interactions", "fragments"],
      "properties": {
        "interactions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "trigger", "dialogue"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "trigger": { "type": "string", "minLength": 1 },
              "dialogue": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "grantsFragment": { "type": "string", "minLength": 1 },
              "grantsFlag": { "type": "string", "minLength": 1 }
            }
          }
        },
        "fragments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "text"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "text": { "type": "string", "minLength": 1 }
            }
          }
        },
        "dusk": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "night": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startVars", "rules", "choices"],
      "properties": {
        "startVars": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "number" }
        },
        "rules": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "choices": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "prompt", "options"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "prompt": { "type": "string", "minLength": 1 },
              "mood": { "$ref": "#/definitions/expression" },
              "options": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["label", "outcome"],
                  "properties": {
                    "label": { "type": "string", "minLength": 1 },
                    "effects": { "type": "array", "items": { "$ref": "#/definitions/effect" } },
                    "unlocks": { "type": "string", "minLength": 1 },
                    "requires": { "$ref": "#/definitions/condition" },
                    "endsNightTo": { "type": "string", "minLength": 1 },
                    "expression": { "$ref": "#/definitions/expression" },
                    "scare": { "type": "boolean" },
                    "outcome": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revealCondition", "text"],
      "properties": {
        "revealCondition": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "endings": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "rank", "text"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "rank": { "type": "string", "enum": ["best", "good", "bad", "worst"] },
          "text": { "type": "string", "minLength": 1 },
          "permanentLoss": { "type": "boolean" },
          "when": { "$ref": "#/definitions/condition" }
        }
      }
    }
  }
}
