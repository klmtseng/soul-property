{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://soul-property/chapter.schema.json",
  "title": "ChapterData",
  "description": "一份章節的完整內容資料。引擎只認此格式，新增章節無需改引擎。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "chapterId", "resident", "day", "night", "truth", "endings"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "chapterId": { "type": "string", "minLength": 1 },
    "resident": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "age", "portraits", "obsessionOneLiner"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "age": { "type": "integer", "minimum": 0 },
        "portraits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["calm", "uneasy", "broken"],
          "properties": {
            "calm": { "type": "string", "minLength": 1 },
            "uneasy": { "type": "string", "minLength": 1 },
            "broken": { "type": "string", "minLength": 1 }
          }
        },
        "obsessionOneLiner": { "type": "string", "minLength": 1 }
      }
    },
    "day": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interactions", "fragments"],
      "properties": {
        "interactions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "trigger", "dialogue", "grantsFragment"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "trigger": { "type": "string", "minLength": 1 },
              "dialogue": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "grantsFragment": { "type": "string", "minLength": 1 }
            }
          }
        },
        "fragments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "text"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "text": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "night": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startRage", "rageThreshold", "rules", "choices"],
      "properties": {
        "startRage": { "type": "integer" },
        "rageThreshold": { "type": "integer" },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "choices": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "prompt", "options"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "prompt": { "type": "string", "minLength": 1 },
              "options": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["label", "rageDelta", "outcome"],
                  "properties": {
                    "label": { "type": "string", "minLength": 1 },
                    "rageDelta": { "type": "integer" },
                    "unlocks": { "type": "string", "minLength": 1 },
                    "scare": { "type": "boolean" },
                    "outcome": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revealCondition", "text"],
      "properties": {
        "revealCondition": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "endings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["good", "bad"],
      "properties": {
        "good": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "text"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "text": { "type": "string", "minLength": 1 }
          }
        },
        "bad": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "permanentLoss", "text"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "permanentLoss": { "type": "boolean" },
            "text": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
